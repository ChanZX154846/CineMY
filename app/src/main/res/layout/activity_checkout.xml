<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".CheckoutActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back_button_desc"
                android:layout_marginBottom="@dimen/vertical_spacing_small"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/checkout_title"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@color/cinemy_text_primary"
                android:layout_marginBottom="@dimen/vertical_spacing_medium"/>

            <TextView
                android:id="@+id/textCheckoutMovie"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/cinemy_text_primary"
                android:paddingTop="@dimen/vertical_spacing_small"
                tools:text="Movie Title"/>

            <TextView
                android:id="@+id/textCheckoutSeats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="@color/cinemy_text_secondary"
                android:paddingTop="@dimen/vertical_spacing_small"
                tools:text="Seats: A1, A2"/>

            <TextView
                android:id="@+id/textTotalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/cinemy_text_primary"
                android:paddingTop="@dimen/vertical_spacing_medium"
                tools:text="Total: RM40"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_payment_method"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/cinemy_text_primary"
                android:paddingTop="@dimen/vertical_spacing_large"/>

            <Spinner
                android:id="@+id/spinnerPayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_spacing_small"
                android:minHeight="48dp"
                tools:listitem="@android:layout/simple_spinner_item"/>

            <Button
                android:id="@+id/btnPayNow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pay_now"
                android:layout_marginTop="@dimen/vertical_spacing_large"
                android:padding="@dimen/inner_padding"/>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cinemy_nav"
        app:itemIconTint="@color/cinemy_primary"
        app:itemTextColor="@color/cinemy_text_primary"
        app:menu="@menu/bottom_menu"/>

</LinearLayout>
