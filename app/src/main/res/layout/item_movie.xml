<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/card_margin"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="@dimen/card_margin"
    android:layout_marginBottom="8dp"
    android:background="@drawable/movie_card_background"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="horizontal"
    android:padding="@dimen/inner_padding">

    <ImageView
        android:id="@+id/imgMovie"
        android:layout_width="92dp"
        android:layout_height="132dp"
        android:background="@drawable/poster_background"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        android:contentDescription="@string/app_name"
        tools:src="@drawable/shangchi"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Movie Title"
            android:textColor="@color/cinemy_text_primary"
            android:textSize="19sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtGenre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            tools:text="Genre"
            android:textColor="@color/cinemy_text_secondary"
            android:textSize="15sp"/>

        <TextView
            android:id="@+id/txtDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            tools:text="2h 10m"
            android:textColor="@color/cinemy_text_secondary"
            android:textSize="15sp"/>

    </LinearLayout>

</LinearLayout>
